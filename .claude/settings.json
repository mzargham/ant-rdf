{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(uv run ant verify*)",
      "Bash(uv run ant compile*)",
      "Bash(uv run ant list*)",
      "Bash(uv run ant ontology validate*)",
      "Bash(uv run ant ontology diff*)",
      "Bash(uv run ant new-record*)",
      "Bash(uv run ant edit-record*)",
      "Bash(uv run ant ingest notes:* --dry-run*)",
      "Bash(uv run ant ingest notes:* --commit*)",
      "Bash(uv run ant ingest transcript*)",
      "Bash(uv run ant ingest observation*)",
      "Bash(uv run ant ingest upload*)",
      "Bash(uv run ant scope*)",
      "Bash(uv run ant query*)",
      "Bash(uv run ant analyze*)",
      "Bash(uv run ant waive list*)",
      "Bash(uv run ant waive add*)",
      "Bash(uv run ant wiki*)",
      "Bash(uv run ant version)",
      "Bash(uv run ant --help)",
      "Bash(uv run pytest*)",
      "Bash(uv sync*)",
      "Bash(uv add*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch --list*)",
      "Bash(git ls-files*)",
      "Bash(gh repo view*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(ls*)",
      "Bash(find*)",
      "Bash(rg*)",
      "Bash(grep*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
      "Read(*)",
      "Edit(briefs/**)",
      "Edit(wiki/**)",
      "Write(briefs/**)",
      "Write(wiki/**)",
      "Edit(instances/**/*.ttl)",
      "Write(instances/**/*.ttl)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git checkout -- *)",
      "Bash(git restore *)",
      "Bash(gh pr merge*)",
      "Bash(gh pr close*)",
      "Bash(gh issue close*)",
      "Bash(gh issue create*)",
      "Bash(gh issue edit*)",
      "Bash(gh issue comment*)",
      "Bash(rm -rf*)",
      "Bash(rm -fr*)"
    ]
  }
}